MYSQLHOST=127.0.0.1
MYSQLPORT=3307
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=oseecoid_toeic
FEATURE_TOEIC=true

# Storage driver: local | r2
TOEIC_STORAGE_DRIVER=local
TOEIC_AUDIO_STORAGE_DRIVER=local
TOEIC_PHOTO_STORAGE_DRIVER=local

# Public URLs for production when using R2/custom domain
R2_PUBLIC_BASE_URL=
R2_AUDIO_PUBLIC_BASE_URL=
R2_PHOTO_PUBLIC_BASE_URL=

# MiniMax/OpenAI generation
MINIMAX_API_KEY=
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1-hd
